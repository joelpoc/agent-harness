# =============================================================================
# agent-harness — environment configuration
# At least ONE model provider key is required to run the agent.
# =============================================================================

# --- Google AI Studio (recommended — free tier, no billing setup needed) ---
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
DEFAULT_MODEL=gemini/gemini-2.5-flash   # or gemini/gemini-2.5-pro for max capability

# --- Anthropic (optional alternative) ---
# ANTHROPIC_API_KEY=sk-ant-...
# DEFAULT_MODEL=anthropic/claude-sonnet-4-5

# --- Vertex AI (optional — requires GCP service account) ---
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json
# VERTEXAI_PROJECT=your-gcp-project
# VERTEXAI_LOCATION=us-central1
# DEFAULT_MODEL=vertex_ai/gemini-2.5-pro

# --- Ollama (optional — air-gapped / offline path) ---
# Install: brew install ollama
# Pull:    ollama pull qwen2.5:14b   (9GB, recommended with 32GB RAM)
#          ollama pull qwen2.5:7b    (4.7GB fallback for <16GB RAM)
# Run:     ollama serve
# DEFAULT_MODEL=ollama/qwen2.5:14b

# --- Harness config (all optional — defaults shown) ---
BUDGET_USD_LIMIT=1.00
AUDIT_LOG_PATH=./audit.jsonl
LOCAL_TRACES_PATH=./traces.jsonl

# --- Arize Phoenix (optional — local trace UI at http://localhost:6006) ---
# Instrumentation uses OpenTelemetry/OTLP — backend-agnostic, swap to any OTel collector.
# PHOENIX_ENABLED=true
# PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
# Launch Phoenix: make phoenix  (or: uv run python -c "import phoenix as px; px.launch_app()")
# Langfuse remains the production team-server choice (not used in this repo — see ADR 007).

# --- Data warehouse (optional — defaults to data/warehouse/) ---
# WAREHOUSE_PATH=data/warehouse
